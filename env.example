# ============================================================
# FLESK BACKEND - Variáveis de Ambiente
# RENOMEIE este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no git
# ============================================================

# URL do projeto Supabase
SUPABASE_URL=https://lrnhtjfneoracdpxbujp.supabase.co

# Chave ANON (pública) - usada para respeitar RLS com o token do usuário
SUPABASE_ANON_KEY=SEU_ANON_KEY_AQUI

# Chave SERVICE ROLE (secreta) - NUNCA exponha no frontend
SUPABASE_SECRET_KEY=SEU_SERVICE_ROLE_KEY_AQUI

# Porta do servidor (padrão: 3001)
PORT=3001

# URL do seu frontend (para CORS em produção)
# Em desenvolvimento: http://localhost:5500 ou http://127.0.0.1:5500
FRONTEND_URL=http://localhost:5500
